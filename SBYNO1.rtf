      const isAge = state.formStep === 0;\
      $('formTitle').textContent = isAge ? '\uc0\u3586 \u3629 \u3619 \u3641 \u3657 \u3592 \u3633 \u3585 \u3588 \u3640 \u3603 \u3609 \u3636 \u3604 \u3609 \u3638 \u3591 ' : '\u3588 \u3640 \u3603 \u3629 \u3618 \u3634 \u3585 \u3619 \u3632 \u3610 \u3640 \u3648 \u3614 \u3624 \u3623 \u3656 \u3634 \u3629 \u3632 \u3652 \u3619 ?';\
      $('formSub').textContent = isAge ? '\uc0\u3648 \u3621 \u3639 \u3629 \u3585 \u3594 \u3656 \u3623 \u3591 \u3629 \u3634 \u3618 \u3640 \u3586 \u3629 \u3591 \u3588 \u3640 \u3603 ' : '\u3648 \u3621 \u3639 \u3629 \u3585 \u3652 \u3604 \u3657  1 \u3588 \u3635 \u3605 \u3629 \u3610 ';\
      const list = isAge ? ageRanges : genders;\
      const selected = isAge ? state.age : state.gender;\
      $('formOptions').innerHTML = list.map(v=>makeOption(\{name:v,value:v,selected:selected===v\})).join('');\
      bindOptionClicks($('formOptions'), value => \{ if(isAge) state.age=value; else state.gender=value; renderForm(); \});\
      $('formBack').textContent = isAge ? '\uc0\u3627 \u3609 \u3657 \u3634 \u3649 \u3619 \u3585 ' : '\u3618 \u3657 \u3629 \u3609 \u3585 \u3621 \u3633 \u3610 ';\
      $('formNext').textContent = isAge ? '\uc0\u3606 \u3633 \u3604 \u3652 \u3611 ' : '\u3648 \u3619 \u3636 \u3656 \u3617 \u3605 \u3629 \u3610 ';\
    \}\
\
    function renderQuiz()\{\
      show('quiz');\
      const q = questions[state.current];\
      const total = questions.length;\
      const pct = Math.round((state.current/total)*100);\
      $('stepLabel').textContent = `\uc0\u3586 \u3657 \u3629  $\{state.current+1\}/$\{total\}`;\
      $('percentLabel').textContent = `$\{pct\}%`;\
      $('bar').style.width = `$\{pct\}%`;\
      $('qTitle').textContent = q.q;\
      $('qOptions').innerHTML = q.a.map((item, idx)=>makeOption(\{name:item[0], value:String(idx), selected:state.answers[state.current]===idx\})).join('');\
      bindOptionClicks($('qOptions'), value => \{ state.answers[state.current] = Number(value); renderQuiz(); \});\
      $('nextBtn').textContent = state.current === total-1 ? '\uc0\u3604 \u3641 \u3612 \u3621 \u3621 \u3633 \u3614 \u3608 \u3660 ' : '\u3606 \u3633 \u3604 \u3652 \u3611 ';\
    \}\
\
    function mascotHTML(type)\{\
      if(type === 'pin') return `<div class="mascot-stage"><div class="map-base"></div><div class="compass"></div><div class="mascot pin-mascot"><div class="inner"><div class="smile"></div></div></div></div>`;\
      if(type === 'shield') return `<div class="mascot-stage"><div class="gate"></div><div class="leaf-l"></div><div class="leaf-r"></div><div class="mascot shield-mascot face"><div class="smile"></div></div></div>`;\
      if(type === 'heart') return `<div class="mascot-stage"><div class="ribbon-wrap"></div><div class="mascot heart-mascot"><div class="face-wrap face"><div class="smile"></div></div></div></div>`;\
      if(type === 'lens') return `<div class="mascot-stage"><div class="worry-cloud"><span>?</span></div><div class="note"></div><div class="mascot lens-mascot"><div class="eyes"></div><div class="mouth"></div></div></div>`;\
      return `<div class="mascot-stage"><div class="compass-ring"></div><div class="signpost"></div><div class="mascot crystal-mascot face"><div class="smile"></div></div></div>`;\
    \}\
\
    function scoreQuiz()\{\
      const scores = \{A:0,B:0,C:0,D:0,E:0\};\
      state.answers.forEach((ans, qi)=>\{\
        const weights = questions[qi].a[ans][1];\
        Object.entries(weights).forEach(([k,v])=>scores[k]+=v);\
      \});\
      const priority = ['E','B','D','C','A'];\
      const max = Math.max(...Object.values(scores));\
      const winners = Object.keys(scores).filter(k=>scores[k]===max);\
      const winner = priority.find(k=>winners.includes(k));\
      return \{scores, winner\};\
    \}\
\
    function renderResult()\{\
      const \{scores, winner\} = scoreQuiz();\
      state.resultKey = winner;\
      const r = results[winner];\
      show('result');\
      $('resultWrap').className = `result-page $\{r.key\}`;\
      $('resultWrap').innerHTML = `\
        <div class="result-head">\
          <div class="eyebrow">RESULT</div>\
          <h2 class="result-title">$\{r.name\}</h2>\
          <div class="tagline">$\{r.tagline\}</div>\
        </div>\
        <div class="result-art">$\{mascotHTML(r.mascot)\}</div>\
        <div class="result-desc-card"><p>$\{r.desc\}</p></div>\
        <div class="badges">$\{r.badges.map(b=>`<span class="badge">$\{b\}</span>`).join('')\}</div>\
        <div class="cta-box"><strong>\uc0\u3617 \u3637 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3652 \u3617 \u3656 \u3649 \u3609 \u3656 \u3651 \u3592 ?</strong><br>$\{r.cta\}</div>\
        <div class="result-actions">\
          <a class="link-btn primary" href="$\{LINE_URL\}" target="_blank" rel="noopener">\uc0\u3649 \u3629 \u3604  LINE Stand by You</a>\
          <button class="secondary" id="shareBtn">\uc0\u3649 \u3594 \u3619 \u3660 \u3612 \u3621 \u3621 \u3633 \u3614 \u3608 \u3660 </button>\
          <button class="secondary" id="allResultsBtn">\uc0\u3604 \u3641 \u3588 \u3634 \u3649 \u3619 \u3585 \u3648 \u3605 \u3629 \u3619 \u3660 \u3607 \u3633 \u3657 \u3591 \u3627 \u3617 \u3604 </button>\
          <button class="secondary" id="restartBtn">\uc0\u3648 \u3621 \u3656 \u3609 \u3651 \u3627 \u3617 \u3656 </button>\
        </div>\
        <div class="status" id="saveStatus">\uc0\u3585 \u3635 \u3621 \u3633 \u3591 \u3610 \u3633 \u3609 \u3607 \u3638 \u3585 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 ...</div>\
      `;\
      $('shareBtn').onclick = shareResult;\
      $('restartBtn').onclick = restart;\
      $('allResultsBtn').onclick = renderAllResults;\
      saveToSheet(scores, winner);\
    \}\
\
    function renderAllResults()\{\
      show('result');\
      const items = Object.entries(results).map(([k,r], idx)=>`\
        <div class="tiny-card $\{r.key\} $\{idx===4?'full':''\}">\
          <p class="mini-title">$\{r.name\}</p>\
          <div class="mini-key">$\{r.badges.join(' \'b7 ')\}</div>\
          <div class="mini-art">$\{mascotHTML(r.mascot)\}</div>\
        </div>\
      `).join('');\
      $('resultWrap').className = 'result-page';\
      $('resultWrap').innerHTML = `\
        <div class="result-head">\
          <div class="eyebrow">ALL RESULTS</div>\
          <h2 class="result-title" style="color:var(--teal)">5 \uc0\u3588 \u3634 \u3649 \u3619 \u3585 \u3648 \u3605 \u3629 \u3619 \u3660 \u3612 \u3621 \u3621 \u3633 \u3614 \u3608 \u3660 </h2>\
          <div class="tagline">\uc0\u3616 \u3634 \u3619 \u3585 \u3636 \u3592 \u3621 \u3633 \u3610 : \u3648 \u3629 \u3634 \u3605 \u3633 \u3623 \u3619 \u3629 \u3604 \u3592 \u3634 \u3585 \u3648 \u3617 \u3639 \u3629 \u3591 \u3588 \u3609 \u3588 \u3640 \u3618 </div>\
        </div>\
        <div class="all-results-grid">$\{items\}</div>\
        <div class="result-actions">\
          <button class="primary" id="backToMyResult">\uc0\u3585 \u3621 \u3633 \u3610 \u3652 \u3611 \u3604 \u3641 \u3612 \u3621 \u3621 \u3633 \u3614 \u3608 \u3660 \u3586 \u3629 \u3591 \u3593 \u3633 \u3609 </button>\
          <button class="secondary" id="restartBtn">\uc0\u3648 \u3621 \u3656 \u3609 \u3651 \u3627 \u3617 \u3656 </button>\
        </div>\
      `;\
      $('backToMyResult').onclick = renderResult;\
      $('restartBtn').onclick = restart;\
    \}\
\
    async function saveToSheet(scores, winner)\{\
      const status = $('saveStatus');\
      if(!status) return;\
      const payload = \{\
        timestamp: new Date().toISOString(),\
        age: state.age,\
        gender: state.gender,\
        resultCode: winner,\
        resultName: results[winner].name,\
        scores,\
        answers: state.answers.map((ans, i)=>(\{questionNo:i+1, question:questions[i].q, answer:questions[i].a[ans][0]\})),\
        userAgent: navigator.userAgent,\
        pageUrl: location.href,\
        sheetId: GOOGLE_SHEET_ID\
      \};\
      if(!SCRIPT_URL || SCRIPT_URL.includes('PASTE_YOUR'))\{\
        status.textContent = '\uc0\u3618 \u3633 \u3591 \u3652 \u3617 \u3656 \u3652 \u3604 \u3657 \u3651 \u3626 \u3656  Google Apps Script Web App URL \u3592 \u3638 \u3591 \u3618 \u3633 \u3591 \u3652 \u3617 \u3656 \u3626 \u3656 \u3591 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3648 \u3586 \u3657 \u3634  Sheet';\
        return;\
      \}\
      try\{\
        await fetch(SCRIPT_URL, \{method:'POST', mode:'no-cors', headers:\{'Content-Type':'text/plain;charset=utf-8'\}, body:JSON.stringify(payload)\});\
        state.saved = true;\
        status.textContent = '\uc0\u3610 \u3633 \u3609 \u3607 \u3638 \u3585 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3648 \u3619 \u3637 \u3618 \u3610 \u3619 \u3657 \u3629 \u3618 ';\
      \}catch(err)\{\
        console.error(err);\
        status.textContent = '\uc0\u3610 \u3633 \u3609 \u3607 \u3638 \u3585 \u3586 \u3657 \u3629 \u3617 \u3641 \u3621 \u3652 \u3617 \u3656 \u3626 \u3635 \u3648 \u3619 \u3655 \u3592  \u3585 \u3619 \u3640 \u3603 \u3634 \u3605 \u3619 \u3623 \u3592 \u3626 \u3629 \u3610  Web App URL';\
      \}\
    \}\
\
    function shareResult()\{\
      const r = results[state.resultKey];\
      const text = `\uc0\u3612 \u3621 \u3621 \u3633 \u3614 \u3608 \u3660 \u3586 \u3629 \u3591 \u3593 \u3633 \u3609 \u3588 \u3639 \u3629  $\{r.name\} \'97 $\{r.tagline\} #StandByYou`;\
      if(navigator.share)\{navigator.share(\{title:'\uc0\u3616 \u3634 \u3619 \u3585 \u3636 \u3592 \u3621 \u3633 \u3610 : \u3648 \u3629 \u3634 \u3605 \u3633 \u3623 \u3619 \u3629 \u3604 \u3592 \u3634 \u3585 \u3648 \u3617 \u3639 \u3629 \u3591 \u3588 \u3609 \u3588 \u3640 \u3618 ', text, url:location.href\}).catch(()=>\{\});\}\
      else\{navigator.clipboard.writeText(text).then(()=>alert('\uc0\u3588 \u3633 \u3604 \u3621 \u3629 \u3585 \u3612 \u3621 \u3621 \u3633 \u3614 \u3608 \u3660 \u3649 \u3621 \u3657 \u3623 '));\}\
    \}\
\
    function restart()\{\
      state.formStep=0; state.age=''; state.gender=''; state.current=0; state.answers=Array(questions.length).fill(null); state.resultKey=null; state.saved=false; show('start');\
    \}\
\
    $('startBtn').onclick = () => renderForm();\
    $('formBack').onclick = () => \{ if(state.formStep===0) show('start'); else \{state.formStep=0; renderForm();\} \};\
    $('formNext').onclick = () => \{\
      if(state.formStep===0)\{ if(!state.age) return alert('\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3648 \u3621 \u3639 \u3629 \u3585 \u3594 \u3656 \u3623 \u3591 \u3629 \u3634 \u3618 \u3640 '); state.formStep=1; renderForm(); return; \}\
      if(!state.gender) return alert('\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3648 \u3621 \u3639 \u3629 \u3585 \u3648 \u3614 \u3624 '); renderQuiz();\
    \};\
    $('prevBtn').onclick = () => \{ if(state.current===0)\{state.formStep=1; renderForm();\} else \{state.current--; renderQuiz();\} \};\
    $('nextBtn').onclick = () => \{\
      if(state.answers[state.current] === null) return alert('\uc0\u3585 \u3619 \u3640 \u3603 \u3634 \u3648 \u3621 \u3639 \u3629 \u3585  1 \u3588 \u3635 \u3605 \u3629 \u3610 ');\
      if(state.current < questions.length-1)\{state.current++; renderQuiz();\}\
      else renderResult();\
    \};\
  </script>\
</body>\
</html>\
}