      \{q:"\uc0\u3606 \u3657 \u3634 \u3588 \u3640 \u3603 \u3617 \u3637 \u3588 \u3635 \u3606 \u3634 \u3617 \u3648 \u3619 \u3639 \u3656 \u3629 \u3591 \u3588 \u3623 \u3634 \u3617 \u3626 \u3633 \u3617 \u3614 \u3633 \u3609 \u3608 \u3660 \u3627 \u3619 \u3639 \u3629 \u3626 \u3640 \u3586 \u3616 \u3634 \u3614 \u3607 \u3637 \u3656 \u3652 \u3617 \u3656 \u3585 \u3621 \u3657 \u3634 \u3606 \u3634 \u3617 \u3612 \u3641 \u3657 \u3651 \u3627 \u3597 \u3656  \u3588 \u3640 \u3603 \u3617 \u3633 \u3585 \u3607 \u3635 \u3618 \u3633 \u3591 \u3652 \u3591 ?", a:[["\u3606 \u3634 \u3617 \u3648 \u3614 \u3639 \u3656 \u3629 \u3609 \u3585 \u3656 \u3629 \u3609  \u3629 \u3618 \u3656 \u3634 \u3591 \u3609 \u3657 \u3629 \u3618 \u3585 \u3655 \u3617 \u3637 \u3588 \u3609 \u3594 \u3656 \u3623 \u3618 \u3588 \u3636 \u3604 ",\{A:2,C:2\}],["\u3648 \u3626 \u3636 \u3619 \u3660 \u3594 \u3648 \u3629 \u3591 \u3648 \u3591 \u3637 \u3618 \u3610  \u3654  \u3627 \u3621 \u3634 \u3618 \u3648 \u3623 \u3655 \u3610 \u3592 \u3609 \u3648 \u3619 \u3636 \u3656 \u3617 \u3591 \u3591 ",\{D:3,A:1\}],["\u3648 \u3585 \u3655 \u3610 \u3652 \u3623 \u3657 \u3585 \u3656 \u3629 \u3609  \u3652 \u3617 \u3656 \u3629 \u3618 \u3634 \u3585 \u3651 \u3627 \u3657 \u3651 \u3588 \u3619 \u3619 \u3641 \u3657 ",\{C:3,D:1\}],["\u3629 \u3618 \u3634 \u3585 \u3606 \u3634 \u3617 \u3588 \u3609 \u3607 \u3637 \u3656 \u3619 \u3641 \u3657 \u3592 \u3619 \u3636 \u3591  \u3649 \u3605 \u3656 \u3605 \u3657 \u3629 \u3591 \u3648 \u3611 \u3655 \u3609 \u3607 \u3637 \u3656 \u3607 \u3637 \u3656 \u3652 \u3617 \u3656 \u3605 \u3633 \u3604 \u3626 \u3636 \u3609 ",\{E:3,B:1\}]]\},\
